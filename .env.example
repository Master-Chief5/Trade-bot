# Copy to .env and fill in. All values are optional.

# Anthropic API key. WITHOUT it, the app still runs and uses a local
# technical-analysis heuristic instead of Claude. WITH it, Claude analyzes the
# chart (and, if you enable news, does web-search sentiment).
ANTHROPIC_API_KEY=

# Model for analysis. Default is claude-opus-4-8 (most capable).
# For cheap/fast polling, use claude-haiku-4-5.
ANTHROPIC_MODEL=claude-opus-4-8

# Port for the web server.
PORT=3000
